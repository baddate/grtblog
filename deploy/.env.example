APP_VERSION=local
IMAGE_REPO_PREFIX=baddate/
# Docker Hub mirror for nginx/postgres/redis (China)
# DOCKER_MIRROR=docker.1ms.run/
DOCKER_MIRROR=

NGINX_PORT=80

POSTGRES_DB=sanblog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

REDIS_PASSWORD=
REDIS_PREFIX=sanblog:

AUTH_SECRET=replace-with-a-strong-secret

APP_UPDATE_CHECK_ENABLED=true
APP_UPDATE_CHECK_REPO=baddate/sanblog
APP_UPDATE_CHANNEL=stable

# Admin panel (build-time, baked into JS bundle)
VITE_APP_BASE=/admin/
VITE_APP_NAME=Sanblog Admin
VITE_APP_TITLE=管理后台
VITE_WATERMARK_CONTENT=
VITE_API_BASE_URL=/api/v2
